run_review() {
  local review_script="$LIB_DIR/wavemill-review.sh"

  if [[ ! -f "$review_script" ]]; then
    echo -e "${RED}Error:${NC} Review script not found at: $review_script" >&2
    exit 1
  fi

  if [[ ! -x "$review_script" ]]; then
    chmod +x "$review_script"
  fi

  echo -e "${CYAN}Starting Wavemill Review...${NC}"
  exec "$review_script" "$@"
}

run_context() {
  local context_script="$LIB_DIR/wavemill-context.sh"

  if [[ ! -f "$context_script" ]]; then
    echo -e "${RED}Error:${NC} Context script not found at: $context_script" >&2
    exit 1
  fi

  if [[ ! -x "$context_script" ]]; then
    chmod +x "$context_script"
  fi

  echo -e "${CYAN}Starting Wavemill Context...${NC}"
  exec "$context_script" "$@"
