# Main command dispatcher
case "${1:-}" in
  mill)
    run_preflight_checks
    shift
    # Parse mill-specific flags before delegating
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --agent)
          export AGENT_CMD="$2"
          export AGENT_CMD_EXPLICIT=true
          shift 2
          ;;
        *)
          break
          ;;
      esac
    done
    run_mill "$@"
    ;;
  expand)
    run_preflight_checks
    shift
    run_expand "$@"
    ;;
  plan)
    run_preflight_checks
    shift
    run_plan "$@"
    ;;
  review)
    run_preflight_checks
    shift
    run_review "$@"
    ;;
  context)
    run_preflight_checks
    shift
    run_context "$@"
    ;;
  eval)
    shift
    run_eval "$@"
    ;;
  init)
    shift
    run_init "$@"
    ;;
  version|--version|-v)
    show_version
    ;;
  help|--help|-h|"")
    show_help
    ;;
  *)
    echo -e "${RED}Error:${NC} Unknown command: $1" >&2
    echo ""
    show_help
    exit 1
    ;;
esac
