  local report_script="$LIB_DIR/wavemill-eval-report.sh"

  if [[ ! -f "$report_script" ]]; then
    echo -e "${RED}Error:${NC} Eval report script not found at: $report_script" >&2
    exit 1
  fi

  if [[ ! -x "$report_script" ]]; then
    chmod +x "$report_script"
  fi

  exec "$report_script" "$@"
}

